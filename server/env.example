# ===========================================
# Nano Banana Pro 服务器配置
# 复制此文件为 .env 并填写配置
# ===========================================

# 端口
PORT=3000

# ===========================================
# 存储配置
# ===========================================

# 存储类型: local (本地) 或 cloud (云存储)
# 本地开发建议用 local，生产环境建议用 cloud
STORAGE_TYPE=local

# ===========================================
# 云存储配置（火山引擎 TOS）
# 仅当 STORAGE_TYPE=cloud 时需要配置
# ===========================================

# 火山引擎 TOS 端点
# 北京: https://tos-cn-beijing.volces.com
# 上海: https://tos-cn-shanghai.volces.com
# 广州: https://tos-cn-guangzhou.volces.com
CLOUD_ENDPOINT=https://tos-cn-beijing.volces.com

# 区域
CLOUD_REGION=cn-beijing

# Bucket名称（需要先在火山引擎控制台创建）
CLOUD_BUCKET=your-bucket-name

# 访问密钥（在火山引擎控制台获取）
CLOUD_ACCESS_KEY=your-access-key-id
CLOUD_SECRET_KEY=your-secret-access-key

# CDN域名（可选，配置后图片通过CDN加速访问）
# 需要在火山引擎CDN控制台配置加速域名
CLOUD_CDN_DOMAIN=cdn.yourdomain.com

# ===========================================
# 阿里云 OSS 配置示例（S3兼容）
# ===========================================
# CLOUD_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# CLOUD_REGION=cn-hangzhou
# CLOUD_BUCKET=your-oss-bucket
# CLOUD_ACCESS_KEY=your-oss-access-key
# CLOUD_SECRET_KEY=your-oss-secret-key

# ===========================================
# 腾讯云 COS 配置示例（S3兼容）
# ===========================================
# CLOUD_ENDPOINT=https://cos.ap-guangzhou.myqcloud.com
# CLOUD_REGION=ap-guangzhou
# CLOUD_BUCKET=your-cos-bucket
# CLOUD_ACCESS_KEY=your-cos-secret-id
# CLOUD_SECRET_KEY=your-cos-secret-key

# ===========================================
# API配置
# ===========================================

# Nano Banana API密钥
NANO_BANANA_API_KEY=your-api-key

# API Host
NANO_BANANA_HOST=https://api.apimart.ai

# 模型名称
NANO_BANANA_MODEL=gemini-3-pro-image-preview

# 备用API密钥（可选）
FALLBACK_API_KEY=your-fallback-api-key
