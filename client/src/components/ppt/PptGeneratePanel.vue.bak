            class="file-input"
            @change="handleFileSelect"
          />
          <div v-if="styleReferenceImages.length === 0" class="upload-placeholder">
            <div class="upload-icon-wrapper">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="17 8 12 3 7 8"></polyline>
                <line x1="12" y1="3" x2="12" y2="15"></line>
              </svg>
            </div>
            <p class="upload-text">ç‚¹ه‡»وˆ–و‹–و‹½ن¸ٹن¼ é£ژو ¼هڈ‚è€ƒه›¾</p>
            <p class="upload-hint">و”¯وŒپ JPGم€پPNGم€پWEBPï¼Œهچ•ه¼ ن¸چè¶…è؟‡ 10MB</p>
          </div>
          <div v-else class="preview-grid">
            <div v-for="(img, index) in styleReferenceImages" :key="index" class="preview-item">
              <img :src="img.preview" :alt="'هڈ‚è€ƒه›¾ ' + (index + 1)" />
              <div class="preview-overlay">
                <button class="remove-btn" @click.stop="removeImage(index)" title="ç§»é™¤">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
