        <div v-if="styleReferenceImages.length > 0" class="style-hint">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
          <span>ه·²هگ¯ç”¨é£ژو ¼هڈ‚è€ƒه›¾ï¼Œç³»ç»ںه°†è‡ھهٹ¨é™„هٹ é£ژو ¼ه¼•ه¯¼وڈگç¤؛è¯?/span>
        </div>
      </div>

      <!-- PPT è„ڑوœ¬هچ،ç‰‡هˆ—è،¨ -->
      <div class="form-group">
        <div class="label-row">
          <label class="label">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            PPT è„ڑوœ¬هچ،ç‰‡
          </label>
          <button class="add-slide-btn" @click="handleAddSlide">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            و·»هٹ é،µé‌¢
          </button>
        </div>
        <div v-if="slides.length === 0" class="empty-slides">
          <p>ç‚¹ه‡»"و·»هٹ é،µé‌¢"ه¼€ه§‹هˆ›ه»?PPT è„ڑوœ¬</p>
        </div>
        <div v-else class="slides-list">
          <PptSlideCard
            v-for="(slide, index) in slides"
            :key="index"
            :index="index"
            :script="slide.script"
            @update:script="handleUpdateSlideScript(index, $event)"
            @remove="handleRemoveSlide(index)"
          />
        </div>
      </div>

      <!-- ç”ںوˆگوŒ‰é’® -->
      <div class="form-actions">
        <button
          class="generate-btn"
          :disabled="!canGenerate || isGenerating"
          @click="handleGenerate"
        >
          <span v-if="!isGenerating">ن¸€é”®ç”ںوˆ?({{ validSlidesCount }} é،?</span>
          <span v-else>ç”ںوˆگن¸?..</span>
        </button>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed } from 'vue'
import PptSlideCard from './PptSlideCard.vue'

const props = defineProps({
  stylePrompt: { type: String, default: '' },
  aspectRatio: { type: String, default: '16:9' },
  styleReferenceImages: { type: Array, default: () => [] },
  slides: { type: Array, default: () => [] },
  isGenerating: { type: Boolean, default: false }
})

const emit = defineEmits([
  'update:stylePrompt',
  'update:aspectRatio',
  'update:styleReferenceImages',
  'update:slides',
  'generate'
])

const ratioOptions = [
  { value: '16:9', label: '16 : 9', preview: '16/9' },
  { value: '21:9', label: '21 : 9', preview: '21/9' },
  { value: '9:16', label: '9 : 16', preview: '9/16' }
]

const localStylePrompt = ref(props.stylePrompt)
const fileInputRef = ref(null)
const isDragOver = ref(false)
const uploadWarning = ref('')
let warningTimer = null

const clearWarningTimer = () => {
  if (warningTimer) clearTimeout(warningTimer)
  warningTimer = setTimeout(() => { uploadWarning.value = '' }, 4000)
}

const validSlidesCount = computed(() => {
  return props.slides.filter(s => s.script && s.script.trim()).length
})

const canGenerate = computed(() => {
  return validSlidesCount.value > 0
})

const handleStylePromptInput = () => {
  emit('update:stylePrompt', localStylePrompt.value)
}

const handleAddSlide = () => {
  const newSlides = [...props.slides, { index: props.slides.length, script: '' }]
  emit('update:slides', newSlides)
}

const handleRemoveSlide = (index) => {
  const newSlides = props.slides.filter((_, i) => i !== index).map((s, i) => ({ ...s, index: i }))
  emit('update:slides', newSlides)
}

const handleUpdateSlideScript = (index, script) => {
  const newSlides = [...props.slides]
  newSlides[index].script = script
  emit('update:slides', newSlides)
}

const triggerUpload = () => {
  fileInputRef.value?.click()
}

const handleFileSelect = async (e) => {
  const files = Array.from(e.target.files || [])
  if (files.length === 0) return

  const maxFiles = 5
  const remaining = maxFiles - props.styleReferenceImages.length
  const toAdd = files.slice(0, remaining)

  const newImages = [...props.styleReferenceImages]

  const skippedFiles = []
  for (const file of toAdd) {
    if (file.size > 10 * 1024 * 1024) {
      skippedFiles.push(file.name)
      continue
    }

    const reader = new FileReader()
    await new Promise((resolve, reject) => {
      reader.onload = (e) => {
        newImages.push({
          preview: e.target.result,
          content: e.target.result,
          name: file.name
        })
        resolve()
      }
      reader.onerror = reject
      reader.readAsDataURL(file)
    })
  }

  if (skippedFiles.length > 0) {
    uploadWarning.value = `${skippedFiles.join('م€?)} è¶…è؟‡ 10MBï¼Œه·²è·³è؟‡`
    clearWarningTimer()
  }

  emit('update:styleReferenceImages', newImages)
  e.target.value = ''
}

const handleDrop = async (e) => {
  isDragOver.value = false
  const files = Array.from(e.dataTransfer?.files || [])
  if (files.length === 0) return

  const maxFiles = 5
  const remaining = maxFiles - props.styleReferenceImages.length
  const toAdd = files.slice(0, remaining)

  const newImages = [...props.styleReferenceImages]

  const skippedFiles = []
  for (const file of toAdd) {
    if (!file.type.startsWith('image/')) continue
    if (file.size > 10 * 1024 * 1024) {
      skippedFiles.push(file.name)
      continue
    }

    const reader = new FileReader()
    await new Promise((resolve, reject) => {
      reader.onload = (e) => {
        newImages.push({
          preview: e.target.result,
          content: e.target.result,
          name: file.name
        })
        resolve()
      }
      reader.onerror = reject
      reader.readAsDataURL(file)
    })
  }

  if (skippedFiles.length > 0) {
    uploadWarning.value = `${skippedFiles.join('م€?)} è¶…è؟‡ 10MBï¼Œه·²è·³è؟‡`
    clearWarningTimer()
  }

  emit('update:styleReferenceImages', newImages)
}

const removeImage = (index) => {
  const newImages = props.styleReferenceImages.filter((_, i) => i !== index)
  emit('update:styleReferenceImages', newImages)
}

const handleGenerate = () => {
  if (canGenerate.value) {
    emit('generate')
  }
}
</script>

